# JSON is recommended because Kaggle team names may contain commas.
KAGGLE_TEAMS=["Example Team A", "Example Team B"]
# Keep this for one account. For multiple accounts, use the JSON array below.
KAGGLE_API_TOKEN=replace-with-a-local-token
KAGGLE_API_TOKENS=[]
KAGGLE_AUTO_DISCOVER_TEAMS=true
KAGGLE_SCAN_WORKERS=2
KAGGLE_REQUEST_INTERVAL_SECONDS=2
